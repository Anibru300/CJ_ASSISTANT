# =============================================================================
# CJ_OS - Plantilla de variables de entorno
# =============================================================================
# Copia este archivo como `.env` y rellena los valores reales.
# NUNCA subas `.env` a un repositorio Git; contiene secretos y rutas locales.
#
# Ubicación esperada: CJ_Assistant/.env
# Documentación: docs/ENVIRONMENT.md
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Configuración general del proyecto
# -----------------------------------------------------------------------------
PROJECT_NAME=CJ_Assistant
PROJECT_VERSION=0.0.6
TIMEZONE=America/Mexico_City
LOG_LEVEL=info
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# 2. Rutas base del sistema (relativas a la raíz del proyecto)
# -----------------------------------------------------------------------------
WORKSPACE_ROOT=./workspace
DOCS_PATH=./docs
CONFIG_PATH=./config
CORE_PATH=./core
AI_PATH=./ai
CONNECTORS_PATH=./connectors
MODULES_PATH=./modules
PROMPTS_PATH=./prompts
TESTING_PATH=./testing
RUNTIME_PATH=./runtime

# -----------------------------------------------------------------------------
# 3. Configuración de Docker
# -----------------------------------------------------------------------------
COMPOSE_FILE=./infrastructure/compose/docker-compose.yml
COMPOSE_PROJECT_NAME=cj_assistant
DOCKER_NETWORK_NAME=cj_network
DOCKER_SUBNET=172.20.0.0/16

# -----------------------------------------------------------------------------
# 4. Configuración de n8n
# -----------------------------------------------------------------------------
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambiar_en_produccion
N8N_ENCRYPTION_KEY=cambiar_por_clave_segura_de_32_caracteres
N8N_API_KEY=cambiar_por_api_key_segura_de_64_caracteres_hex
N8N_DATA_PATH=./runtime/n8n
WEBHOOK_URL=http://localhost:5678/

# -----------------------------------------------------------------------------
# 5. Configuración de PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cj_assistant
POSTGRES_USER=cj_user
POSTGRES_PASSWORD=cambiar_en_produccion
POSTGRES_DATA_PATH=./runtime/database/postgres

# -----------------------------------------------------------------------------
# 6. Configuración de Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=cambiar_en_produccion
REDIS_DATA_PATH=./runtime/database/redis

# -----------------------------------------------------------------------------
# 7. Configuración de agentes de IA
# -----------------------------------------------------------------------------
AGENT_ALMACEN_ENABLED=true
AGENT_ALMACEN_MODEL=kimi-latest
AGENT_CALIDAD_ENABLED=false
AGENT_COMPRAS_ENABLED=false
AGENT_GERENCIA_ENABLED=false
AGENT_LOGISTICA_ENABLED=false
AGENT_RRHH_ENABLED=false
AGENT_SGC_ENABLED=false
AGENT_VENTAS_ENABLED=false

# -----------------------------------------------------------------------------
# 8. Configuración de módulos de negocio
# -----------------------------------------------------------------------------
MODULES_ENABLED=almacen,ventas,sgc
MODULE_ALMACEN_ENABLED=true
MODULE_CALIDAD_ENABLED=false
MODULE_COMPRAS_ENABLED=false
MODULE_GERENCIA_ENABLED=false
MODULE_LOGISTICA_ENABLED=false
MODULE_RRHH_ENABLED=false
MODULE_SGC_ENABLED=true
MODULE_VENTAS_ENABLED=true

# -----------------------------------------------------------------------------
# 9. Integraciones externas
# -----------------------------------------------------------------------------

# OneDrive
ONEDRIVE_PATH=C:/Users/Usuario/OneDrive - Empresa
ONEDRIVE_PROJECT_FOLDER=CJ_Assistant

# Google Drive
GOOGLE_DRIVE_FOLDER=CJ_Assistant_Drive
GOOGLE_SERVICE_ACCOUNT_JSON=./connectors/google/credentials.json

# Outlook / Microsoft 365
OUTLOOK_EMAIL=correo@empresa.com
OUTLOOK_CLIENT_ID=client-id
OUTLOOK_CLIENT_SECRET=client-secret
OUTLOOK_TENANT_ID=tenant-id

# WhatsApp
WHATSAPP_INSTANCE=cj_assistant_prod
WHATSAPP_API_URL=http://localhost:3000
WHATSAPP_API_TOKEN=token-seguro

# Aspel SAE (Firebird)
SAE_DATABASE=C:/Program Files (x86)/Aspel/Aspel-SAE 9.0/Datos/SAE.fdb
SAE_FIREBIRD_HOST=localhost
SAE_FIREBIRD_PORT=3050
SAE_FIREBIRD_USER=SYSDBA
SAE_FIREBIRD_PASSWORD=masterkey

# Excel de almacén
EXCEL_DATABASE=./connectors/excel/almacen.xlsx
EXCEL_SHEET_NAME=Inventario

# -----------------------------------------------------------------------------
# 10. Logs, respaldos y temporales
# -----------------------------------------------------------------------------
LOGS_PATH=./runtime/logs
BACKUPS_PATH=./runtime/backups
BACKUP_RETENTION_DAYS=30
TEMP_PATH=./runtime/temp
CACHE_PATH=./runtime/cache

# -----------------------------------------------------------------------------
# 11. Seguridad
# -----------------------------------------------------------------------------
JWT_SECRET=cambiar_por_clave_jwt_segura_de_64_caracteres_minimo
API_KEY=cambiar_por_api_key_segura
