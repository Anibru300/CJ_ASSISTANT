# =============================================================================
# CJ_OS - Archivos y carpetas ignorados por Git
# =============================================================================

# -----------------------------------------------------------------------------
# Secretos y configuración local
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Datos operativos y volátiles (NO versionar)
# -----------------------------------------------------------------------------
runtime/
02_backups/
03_logs/

# -----------------------------------------------------------------------------
# Credenciales de servicios externos
# -----------------------------------------------------------------------------
connectors/google/credentials.json
connectors/google_drive/credentials.json
connectors/outlook/credentials.json

# -----------------------------------------------------------------------------
# Dependencias y entornos virtuales
# -----------------------------------------------------------------------------
node_modules/
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Cachés y archivos temporales
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.sqlite
*.db

# -----------------------------------------------------------------------------
# Archivos del sistema operativo
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editores e IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Builds y distribuciones
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/

# -----------------------------------------------------------------------------
# Datos sensibles de negocio (ejemplos; ajustar según necesidad)
# -----------------------------------------------------------------------------
# *.fdb
# *.xlsx
# *.xls
